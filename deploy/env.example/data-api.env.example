# Data API / longitudinal datamart reader configuration.
DATALAKE_ROOT_PATH=/var/lib/h2train/datalake
LONGITUDINAL_DATAMART_PATH=datamarts/longitudinal
SERVER_PORT=8081
LOGGING_FILE_PATH=/var/lib/h2train/logs/data-api

APP_DATA_APP_BUS_TYPE=kafka
TIMESERIES_KAFKA_GROUP_ID=h2train-timeseries-projection
TIMESERIES_KAFKA_CLIENT_ID=h2train-timeseries-projection
TIMESERIES_KAFKA_AUTO_OFFSET_RESET=earliest
TIMESERIES_REBUILD_ON_STARTUP=false
