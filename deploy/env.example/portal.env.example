# Portal service configuration.
APP_PERSISTENCE_TYPE=jdbc
APP_BUS_TYPE=kafka
LOGGING_FILE_PATH=/var/lib/h2train/logs/portal

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8080/auth/strava/callback

FITBIT_ENABLED=true
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:8080/auth/fitbit/callback

GOOGLE_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Optional password recovery email delivery.
PASSWORD_RESET_EMAIL_ENABLED=false
PASSWORD_RESET_EMAIL_FROM=no-reply@h2train.local
PASSWORD_RESET_EMAIL_SUBJECT=Reset your H2Train password
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
