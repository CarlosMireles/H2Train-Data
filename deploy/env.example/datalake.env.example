# Datalake writer projection target and Kafka consumer configuration.
DATALAKE_ROOT_PATH=/var/lib/h2train/datalake
APP_BUS_CONSUMER_TYPE=kafka
LOGGING_FILE_PATH=/var/lib/h2train/logs/datalake
DATALAKE_KAFKA_GROUP_ID=h2train-datalake
DATALAKE_KAFKA_CLIENT_ID=h2train-datalake
DATALAKE_KAFKA_AUTO_OFFSET_RESET=earliest
