# Daemon sync and provider access configuration.
APP_PERSISTENCE_TYPE=jdbc
APP_BUS_TYPE=kafka
LOGGING_FILE_PATH=/var/lib/h2train/logs/daemon

SYNC_POLL_INTERVAL_MS=60000
SYNC_CONNECTION_PARALLELISM=4
SYNC_ACTIVITY_PARALLELISM=2
SYNC_METRICS_PARALLELISM=2

PROVIDER_HTTP_CONNECT_TIMEOUT=5s
PROVIDER_HTTP_READ_TIMEOUT=30s

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8080/auth/strava/callback

FITBIT_ENABLED=true
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:8080/auth/fitbit/callback
FITBIT_INITIAL_ACTIVITY_FETCH_LIMIT=10
FITBIT_INCREMENTAL_ACTIVITY_FETCH_LIMIT=20
